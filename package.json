{
  "name": "rpg-map-projector",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "node scripts/local-service.mjs start app",
    "dev:vite": "vite --host 127.0.0.1",
    "local:app": "node scripts/local-service.mjs start app",
    "local:status": "node scripts/local-service.mjs status app",
    "local:stop": "node scripts/local-service.mjs stop app",
    "build": "tsc && vite build",
    "test": "vitest run",
    "test:e2e": "playwright test",
    "check": "npm run test && npm run build && npm run test:e2e"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@types/node": "^25.9.1",
    "typescript": "^6.0.2",
    "vite": "^8.0.4",
    "vitest": "^4.1.4"
  }
}
